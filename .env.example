PORT=5000
MONGO_URI=mongodb://localhost:27017/easybuy

# JWT for users (HS256)
JWT_USER_SECRET=change_this_to_a_long_random_value
JWT_USER_EXPIRES_IN=7d

# JWT for admins (HS256) — MUST be different from JWT_USER_SECRET
JWT_ADMIN_SECRET=change_this_to_a_DIFFERENT_long_random_value
JWT_ADMIN_EXPIRES_IN=1d

# Uploads
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:5000

# Admin seed (used by `npm run seed:admin`)
SEED_ADMIN_EMAIL=admin@easybuycorner.com
SEED_ADMIN_PASSWORD=change_this_admin_password

# OTP settings
OTP_TTL_SECONDS=300

# Shipping fees (BDT)
SHIPPING_FEE_INSIDE_DHAKA=80
SHIPPING_FEE_OUTSIDE_DHAKA=120

# CORS origin for frontend
CORS_ORIGIN=http://localhost:3000

# SMS gateway (Alpha SMS / sms.bd). Leave SMS_PROVIDER blank for console fallback.
SMS_PROVIDER=
SMS_API_URL=https://api.sms.net.bd/sendsms
SMS_API_KEY=
SMS_SENDER_ID=EasyBuyCorner
